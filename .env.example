# ==========================================
# 🏐 VolleyBook Environment Variables
# ==========================================

# [Supabase] Database & Auth
# Get these from Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# [Resend] Email Service (For Auth & Notifications)
RESEND_API_KEY=your_resend_api_key_here

# [Security] Internal Webhooks & API Protection
INTERNAL_WEBHOOK_SECRET=your_internal_webhook_secret_here

# [Upstash] Redis Rate Limiting (Planned)
 UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
 UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here